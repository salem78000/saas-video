{
  "name": "saas-video",
  "version": "0.1.0",
  "private": true,
  "description": "SaaS de génération vidéo multi-shot",
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "npm -w frontend run dev",
    "dev:backend": "npm -w backend run dev",
    "build": "npm -w shared run build && npm -w frontend run build && npm -w backend run build",
    "lint": "npm -w frontend run lint && npm -w backend run lint",
    "db:migrate": "supabase db push",
    "db:reset": "supabase db reset",
    "db:types": "supabase gen types typescript --local > shared/types/database.ts"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "supabase": "^2.15.0",
    "typescript": "^5.7.3"
  }
}
